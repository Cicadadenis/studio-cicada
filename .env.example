# Скопируйте в .env и подставьте значения. В строке ключей не должно быть пробелов вокруг «=».

# --- AI-генерация AST (/api/ai-generate) ---
# safe | advanced — в safe блок get запрещён; в advanced get только с ключом из списка ниже.
# AI_AST_MODE=safe
# Ключи для get (JSON или через запятую). Точное совпадение поля props.key.
# AI_ALLOWED_MEMORY_KEYS=["город","имя","файл"]
# AI_ALLOWED_MEMORY_KEYS=город,имя,файл
# Дополнительные раунды «почини по ошибкам валидации» (0–5, по умолчанию 2).
# AI_AST_REPAIR_ROUNDS=2

# --- Runtime security ---
# auto использует bwrap/firejail при наличии; enforced запрещает запуск DSL без sandbox.
# DSL_SANDBOX_MODE=enforced
# host нужен для реальных Telegram-ботов и HTTP-блоков; none полностью отключает сеть внутри sandbox.
# DSL_SANDBOX_NETWORK=host
# DSL_CPU_SECONDS=60
# DSL_MEMORY_BYTES=536870912
# DSL_MAX_PROCESSES=64
# AVATAR_JSON_LIMIT=7mb
# PREVIEW_JSON_LIMIT=16mb
# SUPPORT_JSON_LIMIT=8mb

# --- Subscriptions / CryptoBot ---
# Минимальная цена тарифа в USD. CryptoBot отклоняет слишком маленькие суммы.
# MIN_SUBSCRIPTION_USD=1.0

# --- Провайдер LLM (/api/ai-generate и др.) ---
# groq | ollama | anthropic. Если пусто: при наличии ANTHROPIC_API_KEY → Claude; иначе при ключах Groq → Groq; иначе Ollama.
# AI_PROVIDER=anthropic

# --- Anthropic Claude (если используешь Claude вместо Groq) ---
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# --- Groq (облачный LLM, OpenAI-совместимый API) ---
# AI_PROVIDER=groq

GROQ_API_KEY=
# Ротация: порядок чтения GROQ_API_KEY → GROQ_TOKEN_1 → GROQ_TOKEN → _2 → _3 (дубликаты убираются).
# Каждый запрос: round-robin «кто первый»; при 401/403/429 и сетевой ошибке — следующий ключ.
# GROQ_TOKEN_1=
# Совместимость: GROQ_TOKEN (= первый запасной слот после TOKEN_1)
# GROQ_TOKEN=

GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Ещё ключи в пул (опционально):
# GROQ_TOKEN_2=
# GROQ_TOKEN_3=

# --- Локальный Ollama (OpenAI-compatible, /v1/chat/completions) ---
# Используется, если AI_PROVIDER=ollama или нет ключей Groq и OLLAMA_URL не указывает на groq.com
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:3b
