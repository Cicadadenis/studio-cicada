# ─── Server ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=3001
CICADA_BIN=/path/to/cicada
# Опциональный checkout cicada-tg. Если пусто, Studio использует установленный пакет cicada-tg.
# Пример Windows: CICADA_TG_ROOT=C:\\Users\\me\\projects\\cicada-tg
# CICADA_TG_ROOT=
# PYTHON=C:\Python312\python.exe

# Google OAuth (email / account linking)
GOOGLE_CLIENT_ID=GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=GOOGLE_CALLBACK_URL
APP_URL=https://example.com

# Browser origins allowed for credentialed CORS (comma-separated). In production without this var, only APP_URL is allowed (set NODE_ENV=production).
# CORS_ORIGINS=https://example.com,https://www.example.com

OLLAMA_URL=https://api.example.com
OLLAMA_MODEL=your-model-name
GROQ_TOKEN=your_groq_token_1
GROQ_TOKEN_2=your_groq_token_2
GROQ_TOKEN_3=your_groq_token_3
DSL_MAX_RUNTIME_MS=300000
DSL_MAX_CODE_BYTES=100000
DSL_MAX_LOG_CHARS=80000

# ─── Vite (фронт) ────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_API_TARGET=http://localhost:3001
VITE_ADMIN_EMAIL=admin@example.com
VITE_TG_BOT_NAME=your_bot_name

# ─── PostgreSQL ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app_db
DB_USER=app_user
DB_PASSWORD=strong_password_here

# ─── Безопасность ────────────────────────────────────────────
ADMIN_KEY=disabled
# В production (NODE_ENV=production): обязателен стабильный JWT_SECRET ≥ 32 символов
JWT_SECRET=super_long_random_secret_key_please_change
JWT_EXPIRES_SEC=604800
# Срок admin cookie (stateless JWT admin_session), секунды. По умолчанию 28800 (8 ч)
# ADMIN_JWT_EXPIRES_SEC=28800
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=App Name <noreply@example.com>

# ─── Telegram ─────────────────────────────────────────────────
# Виджет входа: TG_BOT_TOKEN и @username в VITE_TG_BOT_NAME — от ОДНОГО бота.
# В @BotFather для бота: /setdomain — домен сайта, где открыта страница входа (без https).
# Callback: {VITE_API_URL}/auth/telegram/callback (должен быть доступен с тем же доменом что и API).
TG_BOT_TOKEN=your_telegram_bot_token

# ─── CryptoBot ───────────────────────────────────────────────
CRYPTOBOT_TOKEN=your_cryptobot_token
