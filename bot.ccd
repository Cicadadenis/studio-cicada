бот "1768487637:AAF1vF-TXhtq7OssuWi-T8gSY-9n_i1YvyE"

при старте:
    ответ "Добро пожаловать в Dropbox-бот! 📁"
    кнопки "📄 Загрузить файл" "📁 Просмотреть файлы"
    стоп

при нажатии "📄 Загрузить файл":
    запустить загрузка
    стоп

при нажатии "📁 Просмотреть файлы":
    запустить просмотр
    стоп

сценарий загрузка:
    шаг шаг_загрузки:
        спросить "Отправьте файл для загрузки:" → файл
        сохранить "file_{chat_id)" = {файл}
        ответ "Файл загружен! 📄"
        стоп

сценарий просмотр:
    шаг шаг_просмотра:
        получить "file_{chat_id)" → файл
        ответ "Ваш файл: {файл}"
        стоп
