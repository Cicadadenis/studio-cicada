бот "1768487637:AAHsUUumdRW8JrhsYqgu_5oyub5MvCHbuqM"

при старте:
    ответ "Добро пожаловать! Пожалуйста, авторизируйтесь."
    кнопки "Авторизация"
    стоп

при нажатии "Авторизация":
    спросить "Введите ваш логин:" → логин
    спросить "Введите ваш пароль:" → пароль
    если логин == "admin" && пароль == "12345":
        ответ "Авторизация успешна! 🚀"
    иначе:
        ответ "Неправильный логин или пароль. 😔"
        стоп
