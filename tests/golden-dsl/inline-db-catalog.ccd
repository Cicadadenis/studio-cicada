бот "YOUR_BOT_TOKEN"

глобально категории = ["Пицца", "Напитки"]

при старте:
    ответ "🏠 Главное меню"
    кнопки "📦 Каталог"
    стоп

при нажатии "📦 Каталог":
    ответ "📦 Выберите категорию:"
    inline из бд "категории" callback "cat:" назад "⬅️ Назад" → "back" колонки 2
    стоп

при нажатии:
    если начинается_с(кнопка, "cat:"):
        запомни категория = срез(кнопка, 4)
        ответ "Товары категории: {категория}"
        inline из бд "товары" callback "prod:" назад "⬅️ Категории" → "back_categories"
        стоп
